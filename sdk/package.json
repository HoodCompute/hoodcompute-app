{
  "name": "@hoodcompute/sdk",
  "version": "0.2.0",
  "description": "Typed TypeScript SDK for the HoodCompute decentralized AI inference network. OpenAI-compatible chat completions with on-chain settlement receipts on Robinhood Chain.",
  "license": "MIT",
  "author": "HoodCompute",
  "homepage": "https://hoodcompute.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/hoodcompute/hoodcompute-app.git"
  },
  "bugs": {
    "url": "https://github.com/hoodcompute/hoodcompute-app/issues"
  },
  "keywords": [
    "hoodcompute",
    "ai",
    "inference",
    "llm",
    "openai-compatible",
    "decentralized",
    "robinhood-chain",
    "web3",
    "on-chain",
    "streaming"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
